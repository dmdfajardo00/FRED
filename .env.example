# Frontend build-time env
# Production: leave VITE_API_URL empty → requests go to the Vite proxy in dev,
# or to the configured Vercel env value in prod.
VITE_API_URL=

# Local-dev only. The Vite proxy (vite.config.ts) reads this and attaches it
# as X-API-Key on every /api/* request + rewrites Origin to an allowlisted
# value. The key NEVER reaches the browser. Gitignored via .env.
# Must match the API's API_KEY env var on the VPS.
VITE_DEV_API_KEY=

# FRED scraping scripts (unrelated to the frontend)
FRED_API_KEY=your_32_char_lowercase_alphanumeric_key_here
